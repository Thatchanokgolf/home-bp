# Neon connection string (Netlify env var name must match: DATABASE_URL)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Secret used to sign login tokens (JWT). REQUIRED — auth fails without it.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# Optional SMTP settings for the "Forgot my password" email.
# If these are not set, the reset endpoint returns the new password in the
# response body instead of emailing it (useful for local testing).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Home BP <no-reply@home-bp.local>"
